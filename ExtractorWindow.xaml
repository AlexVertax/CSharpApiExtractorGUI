<Window x:Class="CSharpApiExtractorGUI.ExtractorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:infrastructure="clr-namespace:CSharpApiExtractorGUI.Infrastructure"
        xmlns:models="clr-namespace:CSharpApiExtractorGUI.Models"
        mc:Ignorable="d"
        Title="C# API Extractor"
        Icon="/Assets/project-icon.ico"
        Width="1240"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        Background="#F4F6F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <infrastructure:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8DEE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="#C7D0DC" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="94" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0F62FE" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,1" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0B57D0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0842A0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#17212F" />
            <Setter Property="Background" Value="#E8EDF4" />
            <Setter Property="BorderBrush" Value="#E8EDF4" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D7E0EC" />
                    <Setter Property="BorderBrush" Value="#D7E0EC" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C5D2E2" />
                    <Setter Property="BorderBrush" Value="#C5D2E2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,1" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0B57D0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0842A0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,1" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#D7E0EC" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D7E0EC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#C5D2E2" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#C5D2E2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerIconButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostIconButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Foreground" Value="#B42318" />
            <Setter Property="Background" Value="#FEE4E2" />
            <Setter Property="BorderBrush" Value="#FECACA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,1" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrowseButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,1" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#D7E0EC" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D7E0EC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#C5D2E2" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#C5D2E2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathAddButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="MinWidth" Value="42" />
        </Style>

        <Style x:Key="PathDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostIconButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="MinWidth" Value="42" />
        </Style>

        <Style x:Key="ProjectItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Padding="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="18"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Text="Projects" />
                    <Button Grid.Column="1"
                            Content="+"
                            Style="{StaticResource IconButtonStyle}"
                            Command="{Binding AddProjectCommand}" />
                </Grid>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding ProjectsView}"
                         SelectedItem="{Binding SelectedProject}"
                         ItemContainerStyle="{StaticResource ProjectItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ProjectDefinition}">
                            <Border x:Name="ProjectCard"
                                    Padding="0"
                                    Background="#FCFDFE"
                                    BorderBrush="#D8DEE6"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Grid MinHeight="56">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="ProjectAccent"
                                            Margin="0"
                                            Background="Transparent"
                                            CornerRadius="10,0,0,10" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,12,0"
                                               VerticalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Text="{Binding ListTitle}" />
                                    <Button x:Name="ProjectDeleteButton"
                                            Grid.Column="2"
                                            Margin="0,0,11,0"
                                            Content="×"
                                            Style="{StaticResource DangerIconButtonStyle}"
                                            Opacity="0"
                                            IsHitTestVisible="False"
                                            Command="{Binding DataContext.RemoveProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                    <Setter TargetName="ProjectCard" Property="Background" Value="#F4F8FF" />
                                    <Setter TargetName="ProjectCard" Property="BorderBrush" Value="#2563EB" />
                                    <Setter TargetName="ProjectCard" Property="BorderThickness" Value="2" />
                                    <Setter TargetName="ProjectAccent" Property="Background" Value="#2563EB" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                    <Setter TargetName="ProjectCard" Property="BorderBrush" Value="#93C5FD" />
                                    <Setter TargetName="ProjectDeleteButton" Property="Opacity" Value="1" />
                                    <Setter TargetName="ProjectDeleteButton" Property="IsHitTestVisible" Value="True" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Padding="22"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="ProjectSettingsScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="0,0,6,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#111827" Text="Title" />
                            <TextBox Margin="0,10,0,0"
                                     Text="{Binding SelectedProject.Title, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Padding="16"
                                Style="{StaticResource PanelBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Text="Export Paths" />
                                    <Button Grid.Column="1"
                                            Content="+"
                                            Style="{StaticResource PathAddButtonStyle}"
                                            Command="{Binding AddExportPathRowCommand}" />
                                </Grid>
                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding SelectedProject.ExportPaths}"
                                         ItemContainerStyle="{StaticResource PathListItemStyle}"
                                         Padding="0"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="False">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:PathEntry}">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="42" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="42" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         MinWidth="0"
                                                         HorizontalAlignment="Stretch"
                                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Grid.Column="2"
                                                        Content="..."
                                                        Style="{StaticResource BrowseButtonStyle}"
                                                        Command="{Binding DataContext.BrowseExportPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="4"
                                                        Content="×"
                                                        Margin="0"
                                                        Style="{StaticResource PathDeleteButtonStyle}"
                                                        Command="{Binding DataContext.RemoveExportPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Grid.Row="2"
                                           VerticalAlignment="Center"
                                           Foreground="#B45309"
                                           FontWeight="SemiBold"
                                           Text="Add at least one export path before exporting."
                                           Visibility="{Binding HasExportPathEntries, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="4"
                                Padding="16"
                                Style="{StaticResource PanelBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Text="Exclude Paths (Optional)" />
                                    <Button Grid.Column="1"
                                            Content="+"
                                            Style="{StaticResource PathAddButtonStyle}"
                                            Command="{Binding AddIgnorePathRowCommand}" />
                                </Grid>
                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding SelectedProject.IgnorePaths}"
                                         ItemContainerStyle="{StaticResource PathListItemStyle}"
                                         Padding="0"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="False">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:PathEntry}">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="42" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="42" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         MinWidth="0"
                                                         HorizontalAlignment="Stretch"
                                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Grid.Column="2"
                                                        Content="..."
                                                        Style="{StaticResource BrowseButtonStyle}"
                                                        Command="{Binding DataContext.BrowseIgnorePathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="4"
                                                        Content="×"
                                                        Margin="0"
                                                        Style="{StaticResource PathDeleteButtonStyle}"
                                                        Command="{Binding DataContext.RemoveIgnorePathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Grid.Row="2"
                                           VerticalAlignment="Center"
                                           Foreground="#64748B"
                                           FontStyle="Italic"
                                           Text="Nothing is being ignored."
                                           Visibility="{Binding HasIgnorePathEntries, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="6"
                                Padding="16"
                                Style="{StaticResource PanelBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           Text="Output" />
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="42" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Foreground="#334155" Text="API Reference" />
                                    <TextBox Grid.Column="1"
                                             MinWidth="0"
                                             HorizontalAlignment="Stretch"
                                             Margin="12,0,8,0"
                                             Text="{Binding SelectedProject.ApiRefOutputPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            Content="..."
                                            Style="{StaticResource BrowseButtonStyle}"
                                            Command="{Binding BrowseApiRefOutputPathCommand}" />
                                </Grid>
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="42" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Foreground="#334155" Text="Missing Items (Optional)" />
                                    <TextBox Grid.Column="1"
                                             MinWidth="0"
                                             HorizontalAlignment="Stretch"
                                             Margin="12,0,8,0"
                                             Text="{Binding SelectedProject.MissingItemsOutputPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            Content="..."
                                            Style="{StaticResource BrowseButtonStyle}"
                                            Command="{Binding BrowseMissingItemsOutputPathCommand}" />
                                </Grid>
                                <Grid Grid.Row="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="118" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Foreground="#334155" Text="OneFileDocs Sync URL" />
                                    <TextBox Grid.Column="1"
                                             MinWidth="0"
                                             HorizontalAlignment="Stretch"
                                             Margin="12,0,8,0"
                                             Text="{Binding SelectedProject.OneFileDocsSyncUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            Content="Create"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding OpenOneFileDocsCommand}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="8"
                                Padding="16"
                                Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           Text="Additional Settings" />
                                <CheckBox Margin="0,12,0,0"
                                          Content="Include internal members"
                                          IsChecked="{Binding SelectedProject.IncludeInternalMembers}" />
                                <CheckBox Margin="0,10,0,0"
                                          Content="Include missed items"
                                          IsChecked="{Binding SelectedProject.IncludeMissedItems}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#64748B"
                               Text="Select a project" />
                </Border>

                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#15803D"
                                   FontWeight="SemiBold"
                                   Text="{Binding SaveFeedbackMessage}"
                                   Visibility="{Binding HasSaveFeedback, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Margin="0,0,12,0"
                                    Content="Save"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SaveCommand}" />
                            <Button Content="Export"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ExportCommand}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

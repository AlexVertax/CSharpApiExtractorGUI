<Window x:Class="CSharpApiExtractorGUI.Dialogs.ExportSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Summary"
        Icon="/Assets/project-icon.png"
        Width="520"
        Height="500"
        MinWidth="520"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F6F8">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0F62FE" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0B57D0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0842A0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#17212F" />
            <Setter Property="Background" Value="#E8EDF4" />
            <Setter Property="BorderBrush" Value="#E8EDF4" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D7E0EC" />
                    <Setter Property="BorderBrush" Value="#D7E0EC" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C5D2E2" />
                    <Setter Property="BorderBrush" Value="#C5D2E2" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#0F172A"
                       Text="{Binding ProjectTitle}" />
            <TextBlock Margin="0,8,0,0"
                       FontSize="15"
                       Foreground="#475569"
                       Text="Export completed" />
        </StackPanel>

        <Border Grid.Row="2"
                Padding="16"
                Background="White"
                BorderBrush="#D8DEE6"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Foreground="#475569" Text="Namespaces" />
                <TextBlock Grid.Column="1"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           Text="{Binding NamespaceCount}" />

                <TextBlock Grid.Row="2"
                           Foreground="#475569"
                           Text="Types" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           Text="{Binding TypeCount}" />

                <TextBlock Grid.Row="4"
                           Foreground="#475569"
                           Text="Classes"
                           Margin="16,0,0,0" />
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           Text="{Binding ClassCount}" />

                <TextBlock Grid.Row="6"
                           Foreground="#475569"
                           Text="Interfaces"
                           Margin="16,0,0,0" />
                <TextBlock Grid.Row="6"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           Text="{Binding InterfaceCount}" />

                <TextBlock Grid.Row="8"
                           Foreground="#475569"
                           Text="Structs"
                           Margin="16,0,0,0" />
                <TextBlock Grid.Row="8"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           Text="{Binding StructCount}" />

                <TextBlock Grid.Row="10"
                           Foreground="#475569"
                           Text="Enums"
                           Margin="16,0,0,0" />
                <TextBlock Grid.Row="10"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           Text="{Binding EnumCount}" />

                <TextBlock Grid.Row="12"
                           Foreground="#475569"
                           Text="Records"
                           Margin="16,0,0,0" />
                <TextBlock Grid.Row="12"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           Text="{Binding RecordCount}" />

                <TextBlock Grid.Row="14"
                           Foreground="#475569"
                           Text="Members" />
                <TextBlock Grid.Row="14"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           Text="{Binding MemberCount}" />

                <TextBlock Grid.Row="16"
                           Foreground="#475569"
                           Text="Missed items" />
                <TextBlock Grid.Row="16"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           Text="{Binding MissedItemCount}" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="4"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Content="Show in Explorer"
                    Margin="0,0,12,0"
                    Click="ShowApiReferenceButton_OnClick" />
            <Button Style="{StaticResource SecondaryButtonStyle}"
                    Content="Close"
                    Click="CloseButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
